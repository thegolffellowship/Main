# =============================================================================
# Azure AD / Microsoft Graph API Configuration
# =============================================================================
# Register an app at https://portal.azure.com → App registrations
# Grant it "Mail.Read" (and optionally "Mail.Send") Application permissions
# under Microsoft Graph, then click "Grant admin consent".

AZURE_TENANT_ID=your-directory-tenant-id
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value

# The mailbox to read transaction emails from
EMAIL_ADDRESS=your-email@yourdomain.com

# =============================================================================
# AI Parsing (Anthropic / Claude)
# =============================================================================

# Your Anthropic API key — required for AI-based email parsing.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# Connector / Webhook
# =============================================================================

# API key for the webhook connector endpoint (/api/connector/ingest).
# External systems must send this in the X-API-Key header.
# Generate a random key, e.g.:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CONNECTOR_API_KEY=your-connector-api-key

# =============================================================================
# Daily Email Report
# =============================================================================

# Email address to send the daily transaction report to.
# Leave blank to disable the daily report.
# Requires "Mail.Send" Application permission in Azure AD.
DAILY_REPORT_TO=your-email@yourdomain.com

# Hour of the day (0-23) to send the report (default: 7 = 7:00 AM server time)
DAILY_REPORT_HOUR=7

# =============================================================================
# App Settings
# =============================================================================

# How often to check for new emails (in minutes)
CHECK_INTERVAL_MINUTES=15

# Flask secret key (change this to a random string)
SECRET_KEY=change-me-to-a-random-secret-key
