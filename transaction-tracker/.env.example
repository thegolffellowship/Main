# =============================================================================
# Email Configuration
# =============================================================================
# Uncomment ONE of the sections below depending on your email provider.

# --- Microsoft 365 / Outlook ---
EMAIL_HOST=outlook.office365.com
EMAIL_PORT=993
EMAIL_ADDRESS=your-email@yourdomain.com
EMAIL_PASSWORD=your-app-password

# Microsoft 365: You need an App Password, not your regular password.
# 1. Sign in at https://myaccount.microsoft.com/
# 2. Go to "Security info" (or https://aka.ms/mysecurityinfo)
# 3. Click "+ Add sign-in method" → choose "App password"
# 4. Give it a name (e.g. "Transaction Tracker") and copy the generated password
# 5. Paste it above as EMAIL_PASSWORD
#
# NOTE: Your Microsoft 365 admin must have IMAP enabled for your account.
# If the app can't connect, ask your admin to verify that IMAP access
# is turned on in the Exchange admin center.

# --- Gmail ---
# EMAIL_HOST=imap.gmail.com
# EMAIL_PORT=993
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
#
# Gmail: Use an App Password, not your regular password.
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Paste it above as EMAIL_PASSWORD

# =============================================================================
# App Settings
# =============================================================================

# How often to check for new emails (in minutes)
CHECK_INTERVAL_MINUTES=15

# Flask secret key (change this to a random string)
SECRET_KEY=change-me-to-a-random-secret-key
