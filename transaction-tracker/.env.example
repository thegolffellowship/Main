# =============================================================================
# Azure AD / Microsoft Graph API Configuration
# =============================================================================
# Register an app at https://portal.azure.com → App registrations
# Grant it "Mail.Read" (and optionally "Mail.Send") Application permissions
# under Microsoft Graph, then click "Grant admin consent".

AZURE_TENANT_ID=your-directory-tenant-id
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value

# The mailbox to read transaction emails from
EMAIL_ADDRESS=your-email@yourdomain.com

# =============================================================================
# AI Parsing (Anthropic / Claude)
# =============================================================================

# Your Anthropic API key — required for AI-based email parsing.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# Connector / Webhook
# =============================================================================

# API key for the webhook connector endpoint (/api/connector/ingest).
# External systems must send this in the X-API-Key header.
# Generate a random key, e.g.:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CONNECTOR_API_KEY=your-connector-api-key

# =============================================================================
# Daily Email Report
# =============================================================================

# Email address to send the daily digest to.
# Leave blank to disable the daily digest.
# Requires "Mail.Send" Application permission in Azure AD.
DAILY_REPORT_TO=kerry@thegolffellowship.com

# Hour of the day (0-23) to send the digest (default: 6 = 6:00 AM)
DAILY_REPORT_HOUR=6

# Timezone for the daily digest schedule (default: US/Central)
DAILY_REPORT_TZ=US/Central

# =============================================================================
# Feedback / Support Notifications
# =============================================================================

# Email address to notify instantly when a bug/feature is submitted.
# Falls back to DAILY_REPORT_TO if not set.
# FEEDBACK_NOTIFY_TO=kerry@thegolffellowship.com

# =============================================================================
# RSVP / Golf Genius
# =============================================================================

# Email address that receives Golf Genius round signup confirmations.
# Uses the same Azure AD credentials above (same M365 tenant).
# Leave blank to disable RSVP tracking.
RSVP_EMAIL_ADDRESS=kerry@yourdomain.com

# Optional: separate Azure credentials for the RSVP mailbox.
# If not set, falls back to the main AZURE_* credentials above.
# RSVP_AZURE_TENANT_ID=
# RSVP_AZURE_CLIENT_ID=
# RSVP_AZURE_CLIENT_SECRET=

# =============================================================================
# MCP OAuth (Claude.ai Custom Connector)
# =============================================================================
# Required for Claude.ai to authenticate with the MCP endpoint.
# IMPORTANT: The client secret must be alphanumeric only — no dashes (--),
# no special symbols. Railway's variable parser may strip or mishandle
# values containing double dashes or other special characters.
# Example safe value: TGFmcpSecret2026Railway

MCP_CLIENT_ID=tgf-mcp-client
MCP_CLIENT_SECRET=your-alphanumeric-secret-here

# =============================================================================
# App Settings
# =============================================================================

# How often to check for new emails (in minutes)
CHECK_INTERVAL_MINUTES=15

# Flask secret key (change this to a random string)
SECRET_KEY=change-me-to-a-random-secret-key

# =============================================================================
# Dashboard Access PINs
# =============================================================================

# PIN for full admin access (can edit AND delete items).
# This is for the top-level owner only.
ADMIN_PIN=1234

# PIN for manager access (can view and edit, but NOT delete).
MANAGER_PIN=0000
