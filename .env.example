# =============================================
# TGF Platform - Environment Variables
# =============================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub!

# =============================================
# SUPABASE (Database & Authentication)
# =============================================
# Get these from: Supabase Dashboard > Settings > API
# Your project: https://app.supabase.com/project/gpjvdqzilfuqsghkmpcr

# Public URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://gpjvdqzilfuqsghkmpcr.supabase.co

# Anonymous key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose in frontend! Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# STRIPE (Payment Processing)
# -------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
# Use TEST keys during development (start with sk_test_ and pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================
# APPLICATION
# =============================================
# The URL where your app is hosted (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment (development, staging, production)
NODE_ENV=development

# =============================================
# ADMIN
# =============================================
# Admin email for initial setup
ADMIN_EMAIL=your-admin-email@example.com

# =============================================
# EMAIL (Optional - for v1.1)
# =============================================
# For sending confirmation emails, reminders, etc.
# Using SendGrid or similar service

# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=no-reply@thegolffellowship.com
# EMAIL_FROM_NAME=The Golf Fellowship

# =============================================
# FEATURE FLAGS (Optional - override database)
# =============================================
# These override feature_flags table values if set
# Useful for testing features before enabling in database

# ENABLE_REGISTRATION=true
# ENABLE_MEMBERSHIP_SIGNUP=true
# ENABLE_SOCIAL_AUTH=false
# ENABLE_TGF_PLUS=false
# ENABLE_WALLET=false

# =============================================
# DEVELOPMENT SETTINGS
# =============================================
# Set to 'true' to enable debug logging
# DEBUG_MODE=false

# =============================================
# SECURITY NOTES
# =============================================
# 1. NEVER commit .env.local to git (.gitignore should block it)
# 2. Only use service role keys on the server (never in client code)
# 3. Keep Stripe secret keys secure
# 4. Use test mode keys during development (pk_test_, sk_test_)
# 5. Switch to production keys only when ready to launch
# 6. Rotate keys if they're ever exposed
